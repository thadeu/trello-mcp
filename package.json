{
  "name": "@thadeu/trello-mcp",
  "version": "0.1.9",
  "description": "Universal MCP server for Trello boards, lists, and cards",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "trello-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "inspector": "bunx @modelcontextprotocol/inspector bun dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thadeu/trello-mcp.git"
  },
  "keywords": [
    "mcp",
    "trello",
    "model-context-protocol",
    "kanban"
  ],
  "author": "Thadeu Esteves <dev@thadeu.org>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
