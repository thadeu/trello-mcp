{
  "name": "@thadeu/trello-mcp",
  "version": "0.2.9",
  "description": "Universal MCP server for Trello boards, lists, and cards",
  "bin": {
    "trello-mcp": "bin/trello-mcp.js"
  },
  "files": [
    "bin",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "cd cli && go run .",
    "build:dev": "cd cli && go build -ldflags=\"-s -w\" -o trello-mcp .",
    "build": "bun run scripts/build-binaries.ts",
    "build:local": "bun run scripts/build-binaries.ts $(node -e \"process.stdout.write(process.platform+'-'+process.arch)\")",
    "test": "cd cli && go test ./...",
    "vet": "cd cli && go vet ./...",
    "inspector": "cd cli && go build -o /tmp/trello-mcp . && bunx @modelcontextprotocol/inspector /tmp/trello-mcp",
    "release": "bun run scripts/release.ts",
    "release:patch": "bun run scripts/release.ts patch",
    "release:minor": "bun run scripts/release.ts minor",
    "release:major": "bun run scripts/release.ts major"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thadeu/trello-mcp.git"
  },
  "keywords": [
    "mcp",
    "trello",
    "model-context-protocol",
    "kanban"
  ],
  "author": "Thadeu Esteves <dev@thadeu.org>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=14"
  },
  "optionalDependencies": {
    "@thadeu/trello-mcp-darwin-arm64": "0.2.9",
    "@thadeu/trello-mcp-darwin-x64": "0.2.9",
    "@thadeu/trello-mcp-linux-arm64": "0.2.9",
    "@thadeu/trello-mcp-linux-x64": "0.2.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0"
  }
}
